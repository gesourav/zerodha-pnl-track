{
  "manifest_version": 3,
  "name": "Zerodha P&L Sentinel",
  "version": "1.0",
  "description": "Monitors Zerodha NFO positions and sends Telegram alerts based on group P&L.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://kite.zerodha.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zerodha P&L Tracker"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://kite.zerodha.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
